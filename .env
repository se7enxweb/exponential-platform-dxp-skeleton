###> ibexa/core ###
# Search engine: 'legacy' (built-in, no Solr required) or 'solr'
SEARCH_ENGINE=legacy

# HTTP cache — 'local' for dev; set to 'varnish' on production
HTTPCACHE_PURGE_TYPE=local
HTTPCACHE_DEFAULT_TTL=86400
HTTPCACHE_PURGE_SERVER=http://localhost:80
HTTPCACHE_VARNISH_INVALIDATE_TOKEN=

# Cache pool — 'cache.tagaware.filesystem' for single-server; see config/packages/cache_pool/ for Redis/Memcached
CACHE_POOL=cache.tagaware.filesystem
CACHE_NAMESPACE=ibexa

# MySQL/MariaDB charset/collation — remove for PostgreSQL
DATABASE_CHARSET=utf8mb4
DATABASE_COLLATION=utf8mb4_general_ci

# Set DATABASE_URL in .env.local — Ibexa requires MySQL 8+, MariaDB 10.3+, or PostgreSQL 13+
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< ibexa/core ###
